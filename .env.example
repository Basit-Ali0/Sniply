# --- API (packages/api) — copy to repo root `.env` or `packages/api/.env` ---
# Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# Supabase: Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Supabase: Project Settings → API → anon public key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Upstash Redis: REST URL + token (ioredis uses rediss:// from Upstash console)
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
REDIS_TOKEN=your_upstash_redis_token_if_required_by_client

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Random secret used when deriving API key hashes at rest (document in your secrets manager)
API_KEY_SALT=change_me_to_a_long_random_string

GEOIP_API_URL=http://ip-api.com/json

# --- Frontend (packages/frontend) — copy to packages/frontend/.env.local ---
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
